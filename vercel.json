{
  "version": 2,
  "buildCommand": "cp serverless/go.mod ./go.mod && cp serverless/go.sum ./go.sum",
  "outputDirectory": "public",
  "functions": {
    "serverless/vercel.go": {
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "/serverless/vercel.go"
    },
    {
      "src": "/health",
      "dest": "/serverless/vercel.go"
    },
    {
      "src": "/api/(.*)",
      "dest": "/serverless/vercel.go"
    },
    {
      "src": "/login",
      "dest": "/public/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/config",
      "dest": "/public/config.html"
    },
    {
      "src": "/stats",
      "dest": "/public/stats.html"
    },
    {
      "src": "/logs",
      "dest": "/public/logs.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
