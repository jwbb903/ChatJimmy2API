{
  "version": 2,
  "buildCommand": "cp api/go.mod ./go.mod && cp api/go.sum ./go.sum",
  "functions": {
    "api/vercel.go": {
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "/api/vercel.go"
    },
    {
      "src": "/health",
      "dest": "/api/vercel.go"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/vercel.go"
    },
    {
      "src": "/login",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/config",
      "dest": "/config.html"
    },
    {
      "src": "/stats",
      "dest": "/stats.html"
    },
    {
      "src": "/logs",
      "dest": "/logs.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
